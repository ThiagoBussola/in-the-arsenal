# Guia passo a passo (monorepo, 2 serviços, DNS, migrações): docs/DEPLOY-RAILWAY.md
#
# =============================================================================
# Railway — copia as linhas certas para cada SERVIÇO (Backend ≠ Frontend).
# No dashboard: Service → Variables. Não commits com valores reais.
#
# ORDEM RECOMENDADA (evita “Failed to fetch” / API a morrer na BD):
#   1) Criar PostgreSQL no projeto (New → Database → PostgreSQL).
#   2) No serviço BACKEND: referenciar DATABASE_URL do Postgres + JWT_* + NODE_ENV=production.
#   3) Deploy do backend: migrações — ver backend/railway.toml (releaseCommand) ou corre manualmente
#      `cd backend && DATABASE_URL=... npx sequelize-cli db:migrate` uma vez.
#   4) No serviço FRONTEND: NEXT_PUBLIC_API_SERVER_ORIGIN = URL pública HTTPS do backend (sem /api).
#      (Não uses API_SERVER_URL no front — Railpack falha o build: "secret API_SERVER_URL: not found".)
# =============================================================================

# ---------------------------------------------------------------------------
# SERVIÇO 1: BACKEND (Express / pasta backend)
# ---------------------------------------------------------------------------
NODE_ENV=production
# Railway injeta PORT; podes omitir ou alinhar com o que o Dockerfile/start usa.

# Obrigatório — strings com pelo menos 16 caracteres (gera valores aleatórios fortes)
JWT_SECRET=substitui-por-string-longa-aleatoria-min-16-chars
JWT_REFRESH_SECRET=outra-string-longa-diferente-min-16-chars

# Obrigatório em produção — no Postgres do Railway: Variables → Reference → DATABASE_URL
# (ou cola o valor que o plugin Postgres mostra)
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DBNAME

# Opcional
GOOGLE_CLIENT_ID=
FABCUBE_CARD_FLATTENED_URL=
OPENROUTER_API_KEY=
CARD_SEARCH_SOURCE=hybrid

# ---------------------------------------------------------------------------
# SERVIÇO 2: FRONTEND (Next.js / raiz do repo)
# ---------------------------------------------------------------------------
NODE_ENV=production

# >>> CRÍTICO para login/cadastro/decks/blog funcionarem <<<
# URL pública HTTPS do BACKEND, SEM /api no fim (ex.: https://api.inthearsenal.com).
# Tem de ser NEXT_PUBLIC_* para o Railpack da Railway não exigir "secret" no build.
NEXT_PUBLIC_API_SERVER_ORIGIN=

# Opcional — se definires isto, o browser fala DIRETO com o API (tens de confiar CORS no Express).
# Se não definires, o Next usa /api no mesmo domínio e faz proxy (recomendado).
# NEXT_PUBLIC_API_URL=https://seu-backend.up.railway.app/api

# Opcional — botão “Continuar com Google” no login/registo (mesmo Client ID do Google Cloud)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
